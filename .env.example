# Environment template consumed by the ABSA pipelines.
#
# In CI, UC identifiers come from GitHub environment secrets and are passed
# to `databricks bundle deploy` via --var. API credentials live in a
# Databricks secret scope (default `absa-flood`) and flow into the notebook
# via DAB `{{secrets/scope/key}}` interpolation on base_parameters.
#
# This file is a template only. Do NOT commit real values.

# Unity Catalog identifiers (per environment).
TELM_CATALOG=<unity-catalog-name>
TELM_SCHEMA=<unity-schema-name>
ADDRESS_SOURCE_TABLE=<source-table-with-id-address-columns>

# Databricks auth (service principal + OAuth for paid workspaces).
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<oauth-secret>

# API credentials - stored in the Databricks secret scope, NOT in CI:
#   databricks secrets create-scope absa-flood
#   databricks secrets put-secret absa-flood tomtom_api_key
#   databricks secrets put-secret absa-flood jba_basic_auth
# (jba_basic_auth should include the 'Basic ' prefix.)
